{
  "name": "herdr-factory",
  "version": "0.1.0",
  "description": "Autonomous Jira→PR factory: runs Claude worker agents across repos on herdr worktrees.",
  "type": "module",
  "private": true,
  "bin": {
    "herdr-factory": "bin/herdr-factory",
    "herdr-factory-tui": "bin/herdr-factory-tui"
  },
  "scripts": {
    "cats": "node src/cli/index.ts",
    "tui": "bin/herdr-factory-tui",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "schema": "node src/cli/index.ts schema --stdout > config.schema.json"
  },
  "engines": {
    "node": ">=26.3.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.716.0",
    "@aws-sdk/credential-providers": "^3.716.0",
    "@aws-sdk/lib-storage": "^3.716.0",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.2",
    "@hono/node-server": "^2.0.5",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@opentui/core": "^0.4.2",
    "commander": "^15.0.0",
    "effect": "^3.21.4",
    "hono": "^4.12.26",
    "mime-types": "^3.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
