{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "repo": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "base_ref": {
          "default": "origin/main",
          "type": "string"
        },
        "github": {
          "type": "string"
        }
      },
      "required": [
        "path"
      ]
    },
    "limits": {
      "default": {},
      "type": "object",
      "properties": {
        "max_active_workspaces": {
          "default": 3,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "attention_renotify_seconds": {
          "default": 3600,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "stall_seconds": {
          "default": 2700,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "max_bounces": {
          "default": 6,
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "max_capture_attempts": {
          "default": 5,
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "step_budget_seconds": {
          "default": 3600,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "tick_interval_seconds": {
          "default": 60,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "reconcile_concurrency": {
          "default": 8,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "max_claims_per_tick": {
          "default": 10,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "source_poll_interval_seconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "layout_wait_seconds": {
          "default": 600,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      }
    },
    "work_sources": {
      "minItems": 1,
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "jira"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "poll_interval_seconds": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "jira": {
                "type": "object",
                "properties": {
                  "base_url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "project": {
                    "type": "string"
                  },
                  "status": {
                    "default": {},
                    "type": "object",
                    "properties": {
                      "todo": {
                        "default": "To Do",
                        "type": "string"
                      },
                      "in_development": {
                        "default": "In Progress",
                        "type": "string"
                      },
                      "review": {
                        "default": "In Review",
                        "type": "string"
                      },
                      "done": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  },
                  "auth": {
                    "default": {
                      "method": "api_token"
                    },
                    "oneOf": [
                      {
                        "type": "object",
                        "properties": {
                          "method": {
                            "type": "string",
                            "const": "api_token"
                          }
                        },
                        "required": [
                          "method"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "method": {
                            "type": "string",
                            "const": "oauth"
                          },
                          "client_id": {
                            "type": "string",
                            "minLength": 1
                          },
                          "scopes": {
                            "minItems": 1,
                            "type": "array",
                            "items": {
                              "type": "string",
                              "minLength": 1
                            }
                          }
                        },
                        "required": [
                          "method"
                        ],
                        "additionalProperties": false
                      }
                    ]
                  }
                },
                "required": [
                  "base_url",
                  "project"
                ]
              }
            },
            "required": [
              "type",
              "jira"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "local_markdown"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "poll_interval_seconds": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "local_markdown": {
                "type": "object",
                "properties": {
                  "folder": {
                    "type": "string"
                  }
                },
                "required": [
                  "folder"
                ]
              }
            },
            "required": [
              "type",
              "local_markdown"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "github_issues"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "poll_interval_seconds": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "github_issues": {
                "type": "object",
                "properties": {
                  "repo": {
                    "type": "string",
                    "pattern": "^[\\w.-]+\\/[\\w.-]+$"
                  },
                  "state_labels": {
                    "default": {},
                    "type": "object",
                    "properties": {
                      "in_development": {
                        "default": "herdr:in-development",
                        "type": "string",
                        "minLength": 1
                      },
                      "in_review": {
                        "default": "herdr:in-review",
                        "type": "string",
                        "minLength": 1
                      },
                      "aborted": {
                        "default": "herdr:aborted",
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "additionalProperties": false
                  },
                  "close_on": {
                    "default": {},
                    "type": "object",
                    "properties": {
                      "merged": {
                        "default": true,
                        "type": "boolean"
                      },
                      "done": {
                        "default": true,
                        "type": "boolean"
                      },
                      "aborted": {
                        "default": false,
                        "type": "boolean"
                      }
                    },
                    "additionalProperties": false
                  },
                  "type_labels": {
                    "default": {
                      "bug": "Bug",
                      "defect": "Bug",
                      "chore": "Chore",
                      "task": "Chore",
                      "enhancement": "Feature"
                    },
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "default_type": {
                    "default": "Feature",
                    "type": "string",
                    "minLength": 1
                  },
                  "max_pages": {
                    "default": 1,
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "type",
              "github_issues"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "sentry"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "poll_interval_seconds": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "sentry": {
                "type": "object",
                "properties": {
                  "base_url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "organization": {
                    "type": "string",
                    "minLength": 1
                  },
                  "projects": {
                    "default": [],
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "environment": {
                    "default": [],
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "query": {
                    "default": "is:unresolved",
                    "type": "string"
                  },
                  "stats_period": {
                    "default": "14d",
                    "type": "string",
                    "pattern": "^\\d+[smhdw]$"
                  },
                  "on_merge": {
                    "default": "comment",
                    "type": "string",
                    "enum": [
                      "comment",
                      "none",
                      "resolve",
                      "resolve_in_next_release"
                    ]
                  }
                },
                "required": [
                  "organization"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "type",
              "sentry"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "belt": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "default": 100,
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "workspace_name": {
            "type": "string"
          },
          "match": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "max_bounces": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "default_layout": {
            "type": "string",
            "minLength": 1
          },
          "layout_matching": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "worktree_pattern": {
                  "type": "string",
                  "minLength": 1
                },
                "layout": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "worktree_pattern",
                "layout"
              ],
              "additionalProperties": false
            }
          },
          "steps": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "work",
                    "evidence",
                    "review",
                    "pr",
                    "custom"
                  ]
                },
                "name": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9_-]*$"
                },
                "tab": {
                  "type": "string"
                },
                "pane": {
                  "type": "string"
                },
                "prompt_file": {
                  "type": "string"
                },
                "prompt_file_source": {
                  "type": "string",
                  "enum": [
                    "repo",
                    "config"
                  ]
                },
                "budget_seconds": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "heartbeat": {
                  "default": false,
                  "type": "boolean"
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "name",
          "source",
          "steps"
        ],
        "additionalProperties": false
      }
    },
    "layouts": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "setup": {
            "type": "object",
            "properties": {
              "command": {
                "type": "string",
                "minLength": 1
              },
              "blocking": {
                "default": false,
                "type": "boolean"
              }
            },
            "required": [
              "command"
            ],
            "additionalProperties": false
          },
          "tabs": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "panes": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "title": {
                        "type": "string",
                        "minLength": 1
                      },
                      "command": {
                        "type": "string",
                        "minLength": 1
                      },
                      "setup": {
                        "default": false,
                        "type": "boolean"
                      },
                      "split": {
                        "type": "string",
                        "enum": [
                          "vertical",
                          "horizontal",
                          "right",
                          "down"
                        ]
                      },
                      "ratio": {
                        "type": "number",
                        "exclusiveMinimum": 0,
                        "exclusiveMaximum": 1
                      },
                      "size": {
                        "anyOf": [
                          {
                            "type": "string",
                            "pattern": "^\\d+(\\.\\d+)?%$"
                          },
                          {
                            "type": "number",
                            "exclusiveMinimum": 0
                          }
                        ]
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "required": [
                "panes"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "id",
          "tabs"
        ],
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "cloudfront_domain": {
          "type": "string",
          "minLength": 1
        },
        "key_prefix": {
          "default": "",
          "type": "string"
        },
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "github_username": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "bucket",
        "region",
        "cloudfront_domain"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "repo",
    "work_sources",
    "belt"
  ],
  "title": "herdr-factory repo config (config.yml)",
  "description": "Structural schema for a per-repo config.yml. Cross-field rules (belt.source refs, unique names, layout both-or-neither, workspace_name {{work_id}}, file existence) are validated at load time, not here."
}
