#!/usr/bin/env bash
# Launcher for the herdr-factory TUI. It renders through opentui's native core, which needs
# Node >= 26 with FFI enabled (`--experimental-ffi`). The engine and TUI now share one pinned Node
# (.node-version = 26.x), so this resolves the same Node the engine does:
#   1. the caller's active `node`, if it's already >= 26;
#   2. else the baked Node path (in a managed install, the vendored `runtime/current/bin/node`).
# Resolves its own location through symlinks and runs from the package dir so src/ resolves
# regardless of caller cwd.
set -euo pipefail

src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
pkg="$(cd -P "$(dirname "$src")/.." && pwd)"

cd "$pkg"

entry="src/tui/index.ts"
# --disable-warning keeps Node's experimental-FFI notice off the alternate screen.
node_flags=(--experimental-ffi --disable-warning=ExperimentalWarning)

# opentui can't auto-detect libc — on musl it needs OPENTUI_LIBC=musl to resolve its native lib.
if [ -z "${OPENTUI_LIBC:-}" ] && { ls /lib/ld-musl-* >/dev/null 2>&1 || { command -v ldd >/dev/null 2>&1 && ldd --version 2>&1 | grep -qi musl; }; }; then
  export OPENTUI_LIBC=musl
fi

node_major() { local v; v="$("$1" -v 2>/dev/null)" || return 1; v="${v#v}"; printf '%s' "${v%%.*}"; }

# 1. Active node, if >= 26.
m="$(node_major node || true)"
if [ -n "$m" ] && [ "$m" -ge 26 ]; then
  exec node "${node_flags[@]}" "$entry" "$@"
fi

# 2. Baked node, if it's >= 26 (in a managed install, the vendored runtime/current/bin/node).
baked="${HERDR_FACTORY_STATE_ROOT:-${HOME:-}/.local/state/herdr-factory}/node-path"
if [ -r "$baked" ]; then
  bnode="$(cat "$baked" 2>/dev/null || true)"
  if [ -n "$bnode" ] && [ -x "$bnode" ]; then
    bm="$(node_major "$bnode" || true)"
    if [ -n "$bm" ] && [ "$bm" -ge 26 ]; then
      exec "$bnode" "${node_flags[@]}" "$entry" "$@"
    fi
  fi
fi

echo "herdr-factory-tui requires Node >= 26 with FFI (opentui's native renderer)." >&2
echo "Active node is '$(node -v 2>/dev/null || echo none)', and no usable baked Node path was found ($baked)." >&2
echo "Fix: run install.sh (which vendors a pinned Node 26), or activate Node >= 26 and retry." >&2
exit 1
