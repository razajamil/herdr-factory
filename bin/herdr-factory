#!/usr/bin/env bash
# Launcher for the herdr-factory CLI. Resolves its own location (through symlinks),
# runs from the package dir so src/ resolves regardless of caller cwd.
set -euo pipefail

src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
pkg="$(cd -P "$(dirname "$src")/.." && pwd)"

cd "$pkg"
# Run the CLI directly with `node` — no version manager. The sources are TypeScript executed via
# Node's native type-stripping, and state lives in the built-in `node:sqlite`; both require Node
# >= 24, and there is no native module (no ABI to match). Worker agents sometimes invoke this from
# another repo's worktree whose `node` on PATH may be older, so guard with a clear error instead of
# a cryptic type-stripping failure.
ver="$(node -v 2>/dev/null || true)"
major="${ver#v}"; major="${major%%.*}"
if [ -z "$major" ] || [ "$major" -lt 24 ]; then
  echo "herdr-factory requires Node >= 24 (found '${ver:-none}' on PATH). Activate Node 24+ and retry." >&2
  exit 1
fi
exec node src/cli/index.ts "$@"
