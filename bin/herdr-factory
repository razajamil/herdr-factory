#!/usr/bin/env bash
# Launcher for the herdr-factory CLI. Resolves its own location (through symlinks),
# runs from the package dir so src/ resolves regardless of caller cwd.
set -euo pipefail

src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
pkg="$(cd -P "$(dirname "$src")/.." && pwd)"

cd "$pkg"

# With no arguments, launch the TUI instead of the CLI. It has its own launcher because it renders
# through opentui's native core (Node >= 26 + --experimental-ffi), unlike the Node 24 engine.
if [ "$#" -eq 0 ]; then
  exec "$pkg/bin/herdr-factory-tui"
fi

# The herdr layout event hook has a lean entry (src/cli/layout-hook.ts) so herdr's constantly-firing
# workspace.focused event doesn't load the whole CLI graph just to no-op. Route "layout-hook" there;
# everything else goes through the full CLI (src/cli/index.ts).
entry="src/cli/index.ts"
if [ "$1" = "layout-hook" ]; then
  entry="src/cli/layout-hook.ts"
  shift
fi

# herdr-factory must run on Node >= 26 (native type-stripping + node:sqlite; the TUI additionally
# needs FFI). Prefer the caller's active `node` when it's new enough; otherwise re-exec with the
# Node path the CLI baked on a prior >= 26 run (config.nodePathFile / cli bakeNodePath) — in a
# managed install that's the vendored `<state>/runtime/current/bin/node`. So herdr-factory always
# runs on a good Node regardless of the caller's cwd (worker agents invoke it from other repos'
# worktrees that activate an older node) — with no version-manager dependency at runtime.
node_major() { local v; v="$("$1" -v 2>/dev/null)" || return 1; v="${v#v}"; printf '%s' "${v%%.*}"; }

m="$(node_major node || true)"
if [ -n "$m" ] && [ "$m" -ge 26 ]; then
  exec node "$entry" "$@"
fi

baked="${HERDR_FACTORY_STATE_ROOT:-${HOME:-}/.local/state/herdr-factory}/node-path"
if [ -r "$baked" ]; then
  bnode="$(cat "$baked" 2>/dev/null || true)"
  if [ -n "$bnode" ] && [ -x "$bnode" ]; then
    bm="$(node_major "$bnode" || true)"
    if [ -n "$bm" ] && [ "$bm" -ge 26 ]; then
      exec "$bnode" "$entry" "$@"
    fi
  fi
fi

echo "herdr-factory requires Node >= 26, but the active node is '$(node -v 2>/dev/null || echo none)'" >&2
echo "and no usable baked Node path was found ($baked)." >&2
echo "Fix: run install.sh (which vendors a pinned Node), or run any herdr-factory command once with" >&2
echo "Node >= 26 active to bake the path; afterwards it works from any directory." >&2
exit 1
