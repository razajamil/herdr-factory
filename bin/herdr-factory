#!/usr/bin/env bash
# Launcher for the herdr-factory CLI. Resolves its own location (through symlinks),
# runs from the package dir so src/ resolves regardless of caller cwd.
set -euo pipefail

src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
pkg="$(cd -P "$(dirname "$src")/.." && pwd)"

cd "$pkg"
# herdr-factory must run on Node >= 24 (native type-stripping + node:sqlite). Prefer the caller's
# active `node` when it's new enough; otherwise re-exec with the Node path the CLI baked on a prior
# >= 24 run (config.nodePathFile / cli bakeNodePath). So herdr-factory always runs on its own
# Node 24 regardless of the caller's cwd (worker agents invoke it from other repos' worktrees that
# activate an older node) — with no version-manager dependency at runtime.
node_major() { local v; v="$("$1" -v 2>/dev/null)" || return 1; v="${v#v}"; printf '%s' "${v%%.*}"; }

m="$(node_major node || true)"
if [ -n "$m" ] && [ "$m" -ge 24 ]; then
  exec node src/cli/index.ts "$@"
fi

baked="${HERDR_FACTORY_STATE_ROOT:-${HOME:-}/.local/state/herdr-factory}/node-path"
if [ -r "$baked" ]; then
  bnode="$(cat "$baked" 2>/dev/null || true)"
  if [ -n "$bnode" ] && [ -x "$bnode" ]; then
    bm="$(node_major "$bnode" || true)"
    if [ -n "$bm" ] && [ "$bm" -ge 24 ]; then
      exec "$bnode" src/cli/index.ts "$@"
    fi
  fi
fi

echo "herdr-factory requires Node >= 24, but the active node is '$(node -v 2>/dev/null || echo none)'" >&2
echo "and no usable baked Node path was found ($baked)." >&2
echo "Fix: run any herdr-factory command once with Node >= 24 active (e.g. from this repo's dir, or" >&2
echo "via your version manager) to bake the path; afterwards it works from any directory." >&2
exit 1
