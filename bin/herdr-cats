#!/bin/bash
# herdr-cats — autonomous Jira→PR loop that herds Claude worker agents ("cats")
# across one or more repos.
#
# A single idempotent reconciler ("tick"), driven by launchd, finds eligible Jira
# tickets, spawns one herdr worktree + Claude worker per ticket, watches the PR,
# and tears the worktree down on merge/close. All polling is plain shell (no LLM);
# agents run only to write code and address review comments. Stopping/restarting
# the dispatcher never kills in-flight workers.
#
# Usage: herdr-cats [--repo <name>] <command>
#
# HERDR_CATS_* vars are defined in the sourced config.sh; the capture-lock local
# is consumed by ttllock via dynamic scope. Both confuse shellcheck's per-file view.
# shellcheck disable=SC2034,SC2153

set -euo pipefail

HERDR_CATS_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export HERDR_CATS_HOME

# Leading --repo selects the target repo (its repos/<name>.conf). Also honoured
# via the HERDR_CATS_REPO env var (how the launchd job passes it is by arg).
HERDR_CATS_REPO="${HERDR_CATS_REPO:-}"
if [[ "${1:-}" == "--repo" ]]; then
  HERDR_CATS_REPO="${2:-}"
  shift 2
fi
export HERDR_CATS_REPO

# shellcheck source=/dev/null
source "$HERDR_CATS_HOME/lib/config.sh"
for _lib in log lock jira ledger worktree worker pr watch reconcile; do
  # shellcheck source=/dev/null
  source "$HERDR_CATS_HOME/lib/$_lib.sh"
done

helper_die() { printf 'Error: %s\n' "$1" >&2; exit 1; }
require_arg() { [[ -n "${1:-}" ]] || helper_die "$2 is required"; }
require_repo() { [[ -n "$HERDR_CATS_REPO" ]] || helper_die "this command needs a repo: herdr-cats --repo <name> ${SUBCMD:-<command>}"; }

# --- subcommands ------------------------------------------------------------

cmd_tick() {
  require_repo
  log_init
  if ! pidlock_acquire tick; then
    log_info "another tick is already running — skipping"
    exit 0
  fi
  trap 'pidlock_release tick' EXIT
  reconcile_all
}

cmd_status() {
  require_repo
  ledger_dir_init
  printf 'herdr-cats [%s] — board %s, label "%s", cap %s, watch %sh\n\n' \
    "$HERDR_CATS_REPO" "$HERDR_CATS_JIRA_BOARD" "$HERDR_CATS_JIRA_LABEL" "$HERDR_CATS_MAX_ACTIVE" "$HERDR_CATS_WATCH_HOURS"
  printf 'Active: %s/%s\n' "$(ledger_count_active)" "$HERDR_CATS_MAX_ACTIVE"
  local key
  for key in $(ledger_active_keys); do
    printf '  %-12s %-12s %-40s PR:%-5s ws:%s\n' \
      "$key" "$(ledger_get "$key" phase)" "$(ledger_get "$key" branch)" \
      "$(ledger_get "$key" pr_number)" "$(ledger_get "$key" workspace_id)"
  done
  if command -v launchctl >/dev/null 2>&1; then
    printf '\nlaunchd: '
    launchctl list 2>/dev/null | grep -q "$HERDR_CATS_LAUNCHD_LABEL" && printf 'loaded (%s)\n' "$HERDR_CATS_LAUNCHD_LABEL" || printf 'not loaded\n'
  fi
}

cmd_eligible() {
  require_repo
  jira_require_auth || exit 1
  jira_list_eligible | jq .
}

# The capture lock is machine-global (one dev server / browser at a time across
# ALL repos), so it lives in the shared locks dir and needs no repo.
cmd_capture_lock() {
  local action
  local owner
  local HERDR_CATS_LOCKS_DIR
  action="${1:-}"
  owner="${2:-worker}"
  HERDR_CATS_LOCKS_DIR="$HERDR_CATS_SHARED_LOCKS_DIR"
  case "$action" in
    acquire)
      if ttllock_acquire_blocking capture "$owner" 1200 3600 5; then
        printf 'capture lock acquired by %s\n' "$owner"
      else
        helper_die "timed out waiting for capture lock"
      fi
      ;;
    release) ttllock_release capture "$owner"; printf 'capture lock released by %s\n' "$owner" ;;
    *) helper_die "capture-lock: acquire|release <owner>" ;;
  esac
}

cmd_claim() {
  require_repo
  local key
  local ticket
  key="${1:-}"
  require_arg "$key" "ticket key"
  jira_require_auth || exit 1
  ticket="$(jira_get_issue "$key" | jq -c '{key: .key, summary: .fields.summary, type: .fields.issuetype.name}')"
  reconcile_claim "$ticket"
}

cmd_teardown() {
  require_repo
  local key
  key="${1:-}"
  require_arg "$key" "ticket key"
  log_init
  reconcile_teardown "$key"
}

cmd_install()   { require_repo; "$HERDR_CATS_HOME/install-launchd.sh" install; }
cmd_uninstall() { require_repo; "$HERDR_CATS_HOME/install-launchd.sh" uninstall; }
cmd_start()     { require_repo; "$HERDR_CATS_HOME/install-launchd.sh" start; }
cmd_stop()      { require_repo; "$HERDR_CATS_HOME/install-launchd.sh" stop; }

cmd_logs() {
  require_repo
  local f
  f="$HERDR_CATS_LOGS_DIR/$(date '+%Y-%m-%d').log"
  [[ -f "$f" ]] && tail -n "${1:-50}" "$f" || printf 'no log for today at %s\n' "$f"
}

cmd_help() {
  cat <<EOF
herdr-cats — autonomous Jira→PR loop (herds Claude "cat" agents across repos)

Usage: herdr-cats [--repo <name>] <command>

  --repo <name>      Select the target repo (its ~/.config/herdr-cats/repos/<name>.conf)

  tick               Run one reconcile pass (what launchd invokes)
  status             Show active tickets + launchd state for the repo
  eligible           List eligible "$HERDR_CATS_STATUS_TODO" + "$HERDR_CATS_JIRA_LABEL" tickets
  claim <KEY>        Manually claim + start one ticket (debug)
  teardown <KEY>     Manually tear down one ticket's worktree (debug)
  capture-lock acquire|release <owner>   Shared (machine-global) dev-server/screenshot lock
  install            Install the launchd job for the repo (com.herdr-cats.<repo>)
  uninstall          Remove the repo's launchd job
  start | stop       Load / unload the repo's launchd job (workers keep running)
  logs [N]           Tail today's log for the repo
  help               This help

Setup a new repo: write ~/.config/herdr-cats/repos/<name>.conf (see examples/),
define its herdr layout, then: herdr-cats --repo <name> install
EOF
}

main() {
  SUBCMD="${1:-help}"
  case "$SUBCMD" in
    tick)         cmd_tick ;;
    status)       cmd_status ;;
    eligible)     cmd_eligible ;;
    claim)        cmd_claim "${@:2}" ;;
    teardown)     cmd_teardown "${@:2}" ;;
    capture-lock) cmd_capture_lock "${@:2}" ;;
    install)      cmd_install ;;
    uninstall)    cmd_uninstall ;;
    start)        cmd_start ;;
    stop)         cmd_stop ;;
    logs)         cmd_logs "${@:2}" ;;
    help|--help|-h) cmd_help ;;
    *) helper_die "Unknown command: ${SUBCMD}. Try 'herdr-cats help'." ;;
  esac
}

main "$@"
